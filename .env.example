# LLM Provider Preference (ollama, openai, gemini, azure, llmfarm, mock)
LLM_PROVIDER=ollama
# Enable auto-detection/fallback to Ollama if no provider is configured
LLM_FALLBACK_TO_OLLAMA=false

# API Keys (Provider-specific keys take precedence)
# LLM_API_KEY_AZURE=
# LLM_API_KEY_LLMFARM=
# LLM_API_KEY_GEMINI=
# LLM_API_KEY_OPENAI=
# LLM_API_KEY=

# Azure OpenAI Configuration
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_VERSION=
# AZURE_OPENAI_DEPLOYMENT=

# LLM Farm Configuration
# LLMFARM_ENDPOINT=
# LLMFARM_MODEL=

# OpenAI Configuration
# OPENAI_MODEL=gpt-4

# Ollama Model Configuration
OLLAMA_MODEL=qwen2.5-coder:7b
